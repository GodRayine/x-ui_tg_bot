BOT_TOKEN=123456:ABCDEF...

# 3x-ui
XUI_BASE_URL=http://127.0.0.1:2053
XUI_USERNAME=admin
XUI_PASSWORD=pass

# Где храните tg_id в клиенте (лучше всего: email или remark)
# Например в 3x-ui в email писать "tg:123456789"
XUI_TGID_FIELD=email

# Что считать "активным":
# online  = прямо сейчас онлайн (POST /panel/api/inbounds/onlines)
# enabled = включён и не просрочен (enable=true и expiryTime не истёк)
XUI_ACTIVE_MODE=online

# админы бота (через запятую)
ADMIN_IDS=111111111,222222222

# база пользователей бота
DB_PATH=users.db